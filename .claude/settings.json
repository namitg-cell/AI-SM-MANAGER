{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(source:*)",
      "Bash(export:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(pwd:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(sort:*)",
      "Bash(tree:*)",
      "Bash(diff:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(bash scripts/:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | grep -q 'posts-log' && echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"additionalContext\": \"QUALITY GATE REMINDER: Ensure all posts pass quality checks before logging. Verify: no em dashes, character limits met, no banned words, hashtags present, no placeholders.\"}}' || echo '{}'",
            "timeout": 10,
            "statusMessage": "Checking quality gate..."
          }
        ]
      }
    ]
  }
}
